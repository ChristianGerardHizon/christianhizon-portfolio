{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "dev",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "--web-port=8000",
                "--dart-define=ENV=dev",
                "--dart-define=API_URL=http://127.0.0.1:8090"
            ]
        },
        {
            "name": "staging",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "--web-port=8000",
                "--dart-define=ENV=staging",
                "--dart-define=API_URL=https://staging.hizonelaundry.sannjoseanimalclinic.com"
            ]
        },
        {
            "name": "staging | release",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "program": "lib/main.dart",
            "args": [
                "--web-port=8000",
                "--dart-define=ENV=staging",
                "--dart-define=API_URL=https://staging.hizonelaundry.sannjoseanimalclinic.com"
            ]
        },
        {
            "name": "prod (local test)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "--web-port=8000",
                "--dart-define=ENV=prod",
                "--dart-define=API_URL=https://hizonelaundry.sannjoseanimalclinic.com"
            ]
        },
        {
            "name": "prod | release",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "program": "lib/main.dart",
            "args": [
                "--web-port=8000",
                "--dart-define=ENV=prod",
                "--dart-define=API_URL=https://hizonelaundry.sannjoseanimalclinic.com"
            ]
        },
        {
            "name": "profile mode",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "program": "lib/main.dart"
        },
        {
            "name": "release mode",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "program": "lib/main.dart"
        },
        {
            "name": "example app",
            "request": "launch",
            "type": "dart",
            "program": "docs/examples/main_example.dart",
            "args": [
                "--web-port=8001"
            ]
        }
    ]
}
